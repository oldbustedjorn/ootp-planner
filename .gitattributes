# ------------------------------
# NORMALIZE LINE ENDINGS
# ------------------------------
# Store text files in the repo as LF.
# When checking out on Windows, convert LF → CRLF in working directory.
# Prevents LF/CRLF warnings and makes history consistent.
* text=auto

# ------------------------------
# PYTHON FILES
# ------------------------------
*.py text eol=lf
*.pyi text eol=lf

# Ensure shell scripts stay LF-only
*.sh text eol=lf

# ------------------------------
# JSON / YAML / TOML / Config
# ------------------------------
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf

# ------------------------------
# DOCUMENTATION
# ------------------------------
*.md text eol=lf
*.txt text eol=lf
*.rst text eol=lf

# ------------------------------
# CODE / DATA (common)
# ------------------------------
*.csv text eol=lf
*.tsv text eol=lf
*.xml text eol=lf

# ------------------------------
# BINARY FILES (never diff these)
# ------------------------------
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.gz binary
*.rar binary
*.exe binary
*.dll binary
*.so binary
*.pdf binary
